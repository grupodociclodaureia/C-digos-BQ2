;; ============================================================
;; CICLO DA UREIA - 4 Quadrantes (com reposição de NH3 via sliders)
;; Sliders esperados na Interface:
;; nh3-initial, nag-initial, ureia-probability,
;; nh3-replenish-threshold, nh3-replenish-amount, nh3-replenish-interval, auto-replenish?
;; ============================================================

globals [
  nh3-replenish-threshold
  nh3-replenish-amount
  nh3-replenish-interval
  auto-replenish?
]

;; --- BREEDS: COMPOSTOS ---
breed [nh3s nh3]
breed [co2s co2]
breed [nags nag]
breed [carbamoils-fosfatos carbamoil-fosfato]
breed [ortininas ortinina]
breed [citrulinas citrulina]
breed [fosfatos-inorganicos fosfato-inorganico]
breed [citrulils-amp citrulil-amp]
breed [argininosuccinatos argininosuccinato]
breed [argininas arginina]
breed [aspartatos aspartato]
breed [aguas agua]
breed [atps atp]
breed [amps amp]
breed [fumaratos fumarato]
breed [ureias ureia]

;; --- BREEDS: ENZIMAS ---
breed [cps1s cps1]
breed [otcs otc]
breed [ass1s ass1]
breed [asls asl]
breed [args arg]

turtles-own [
  compartment
  allowed-zones
  birth-tick
]

patches-own [
  zone
]

to-report cytosol-zones
  report ["top-left" "top-right" "bot-left"]
end

to setup
  clear-all

  if not is-number? nh3-initial [ set nh3-initial 10 ]
  if not is-number? nag-initial [ set nag-initial 5 ]
  if not is-number? ureia-probability [ set ureia-probability 0.5 ]

  ;; defaults para sliders de reposição de NH3
  if not is-number? nh3-replenish-threshold [ set nh3-replenish-threshold 3 ]
  if not is-number? nh3-replenish-amount [ set nh3-replenish-amount 1 ]
  if not is-number? nh3-replenish-interval [ set nh3-replenish-interval 1 ]
  if not is-boolean? auto-replenish? [ set auto-replenish? true ]

  ;; garante que o intervalo não seja zero ou negativo
  if nh3-replenish-interval <= 0 [ set nh3-replenish-interval 1 ]

  ask patches [
    ifelse pycor >= 0 [
      ifelse pxcor < 0 [
        set zone "top-left"
        set pcolor violet + 3
      ][
        set zone "top-right"
        set pcolor violet + 3
      ]
    ][
      ifelse pxcor < 0 [
        set zone "bot-left"
        set pcolor violet + 3
      ][
        set zone "bot-right"
        set pcolor green + 1
      ]
    ]
  ]

  create-nh3s nh3-initial [
    set allowed-zones ["bot-right"]
    place-in "bot-right"
    set color violet - 1 set size 0.8 set shape "square"
  ]

  create-co2s 10 [
    set allowed-zones ["bot-right"]
    place-in "bot-right"
    set color violet - 1 set size 1.3 set shape "cloud"
  ]

  create-nags nag-initial [
    set allowed-zones ["bot-right"]
    place-in "bot-right"
    set color violet - 1 set size 0.8 set shape "triangle"
  ]

  create-ortininas 6 [
    set allowed-zones (sentence cytosol-zones ["bot-right"])
    place-in "top-right"
    set color yellow set size 2.0 set shape "circle"
  ]

  create-aspartatos 8 [
    set allowed-zones cytosol-zones
    place-in "top-right"
    set color cyan - 1 set size 2 set shape "circle"
  ]

  create-atps 8 [
    set allowed-zones cytosol-zones
    place-in "bot-left"
    set color orange set size 1.9 set shape "lightning"
  ]

  create-aguas 8 [
    set allowed-zones cytosol-zones
    place-in "top-right"
    set color sky set size 1.5 set shape "drop"
  ]

  create-cps1s 3 [
    set allowed-zones ["bot-right"]
    place-in "bot-right"
    set color violet - 1 set size 0.8 set shape "star"
  ]

  create-otcs 3 [
    set allowed-zones ["bot-right"]
    place-in "bot-right"
    set color red set size 2.5 set shape "star"
  ]

  create-ass1s 3 [
    set allowed-zones cytosol-zones
    place-in "bot-left"
    set color magenta + 1 set size 2.5 set shape "star"
  ]

  create-asls 3 [
    set allowed-zones cytosol-zones
    place-in "top-left"
    set color red - 2 set size 2.5 set shape "star"
  ]

  create-args 3 [
    set allowed-zones cytosol-zones
    place-in "top-right"
    set color violet - 2 set size 2.5 set shape "star"
  ]

  reset-ticks
end

to place-in [zone-name]
  let target-patches patches with [zone = zone-name]
  move-to one-of target-patches
  set compartment zone-name
end

to move-molecules
  ask turtles [
    let allowed-patches patches with [member? zone [allowed-zones] of myself]
    let next-patch one-of neighbors4 with [member? self allowed-patches]
    if next-patch != nobody [
      move-to next-patch
      set compartment [zone] of next-patch
    ]
  ]
end

to repor-substratos
  ;; protege contra intervalo inválido no momento da reposição
  if nh3-replenish-interval <= 0 [ set nh3-replenish-interval 1 ]

  if auto-replenish? [
    if nh3-replenish-interval > 0 [
      if (ticks mod nh3-replenish-interval) = 0 [
        if count nh3s < nh3-replenish-threshold [
          let deficit nh3-replenish-threshold - count nh3s
          let to-create min (list nh3-replenish-amount deficit)
          if to-create > 0 [
            create-nh3s to-create [
              set allowed-zones ["bot-right"]
              place-in "bot-right"
              set color violet - 1 set size 0.8 set shape "square"
            ]
          ]
        ]
      ]
    ]
  ]

  if count co2s < 3 [
    create-co2s 1 [
      set allowed-zones ["bot-right"]
      place-in "bot-right"
      set color violet - 1 set size 1.3 set shape "cloud"
    ]
  ]

  if count aspartatos < 3 [
    create-aspartatos 1 [
      set allowed-zones cytosol-zones
      place-in "top-right"
      set color cyan - 1 set size 2 set shape "circle"
    ]
  ]

  if count atps < 3 [
    create-atps 1 [
      set allowed-zones cytosol-zones
      place-in "bot-left"
      set color orange set size 1.9 set shape "lightning"
    ]
  ]

  if count aguas < 3 [
    create-aguas 1 [
      set allowed-zones cytosol-zones
      place-in "top-right"
      set color sky set size 1.5 set shape "drop"
    ]
  ]
end

to react
  ask cps1s [
    let near-nag nags in-radius 3
    let near-nh3 nh3s in-radius 2
    let near-co2 co2s in-radius 2
    if any? near-nh3 and any? near-co2 [
      let nag-count count near-nag
      let activation-probability min (list 1 (0.2 * nag-count))
      if random-float 1.0 < activation-probability [
        ask one-of near-nh3 [ die ]
        ask one-of near-co2 [ die ]
        hatch-carbamoils-fosfatos 1 [
          set allowed-zones ["bot-right"]
          place-in "bot-right"
          set color blue - 1 set size 2 set shape "circle"
        ]
      ]
    ]
  ]

  ask otcs [
    let near-carbamoil carbamoils-fosfatos in-radius 2
    let near-ort ortininas with [compartment = "bot-right"] in-radius 2
    if any? near-carbamoil and any? near-ort [
      ask one-of near-carbamoil [ die ]
      ask one-of near-ort [ die ]
      hatch-citrulinas 1 [
        set allowed-zones (sentence cytosol-zones ["bot-right"])
        set color yellow + 3 set size 2.0 set shape "circle"
        place-in "bot-right"
      ]
      hatch-fosfatos-inorganicos 1 [
        set allowed-zones cytosol-zones
        set color grey - 2 set size 1.8 set shape "default"
        place-in "bot-right"
      ]
    ]
  ]

  ask ass1s [
    let near-cit citrulinas with [member? compartment cytosol-zones] in-radius 2
    let near-asp aspartatos in-radius 2
    let near-atp atps in-radius 2
    if any? near-cit and any? near-asp and any? near-atp [
      ask one-of near-cit [ die ]
      ask one-of near-asp [ die ]
      ask one-of near-atp [ die ]
      hatch-citrulils-amp 1 [
        set allowed-zones cytosol-zones
        set color pink - 3 set size 6 set shape "cow"
        set birth-tick ticks + 20
        place-in compartment
      ]
      hatch-amps 1 [
        set allowed-zones cytosol-zones
        set color pink set size 1.3 set shape "square"
        place-in compartment
      ]
    ]
  ]

  ask citrulils-amp with [ticks >= birth-tick] [
    hatch-argininosuccinatos 1 [
      set allowed-zones cytosol-zones
      set color green set size 2.0 set shape "circle"
      place-in compartment
    ]
    die
  ]

  ask asls [
    let near-argsu argininosuccinatos in-radius 2
    if any? near-argsu [
      ask one-of near-argsu [ die ]
      hatch-argininas 1 [
        set allowed-zones cytosol-zones
        set color green - 2 set size 2.0 set shape "circle"
        place-in compartment
      ]
      hatch-fumaratos 1 [
        set allowed-zones cytosol-zones
        set color brown - 3 set size 1.2 set shape "square"
        place-in compartment
      ]
    ]
  ]

  ask args [
    let near-arg argininas in-radius 2
    let near-agua aguas in-radius 2
    if any? near-arg and any? near-agua [
      if random-float 1.0 < ureia-probability [
        ask one-of near-arg [ die ]
        ask one-of near-agua [ die ]
        hatch-ureias 1 [
          set allowed-zones cytosol-zones
          set color white set size 1.9 set shape "suit diamond"
          place-in compartment
        ]
        hatch-ortininas 1 [
          set allowed-zones (sentence cytosol-zones ["bot-right"])
          set color yellow set size 2.0 set shape "circle"
          place-in compartment
        ]
      ]
    ]
  ]
end

to go
  move-molecules
  react
  repor-substratos
  tick
end
